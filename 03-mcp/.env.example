# ===== 模型 Provider =====
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ===== Logfire 可观测性（05-production/05-debugging-inspector 用） =====
LOGFIRE_TOKEN=lf_xxx
LOGFIRE_PROJECT=mcp-tutorial

# ===== MCP Inspector =====
MCP_INSPECTOR_PORT=6274

# ===== 远程 MCP（05-production 用） =====
MCP_REMOTE_HOST=0.0.0.0
MCP_REMOTE_PORT=8765
MCP_REMOTE_BASE_URL=http://localhost:8765

# ===== OAuth（05-production/02-auth-oauth 用） =====
MCP_OAUTH_ISSUER=https://your-idp.example.com
MCP_OAUTH_CLIENT_ID=mcp-client-xxx
MCP_OAUTH_CLIENT_SECRET=secret-xxx
MCP_OAUTH_AUDIENCE=https://mcp.your-domain.example.com

# ===== 实战项目（07-practice 用） =====
KB_VECTOR_DIR=./demos/practice/internal_kb/chroma
DB_READONLY_URL=sqlite:///./demos/practice/db_mcp/sample.db

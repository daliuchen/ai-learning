OPENAI_API_KEY=sk-...

# Tracing（默认走 OpenAI Platform Dashboard）
# 关闭可设：
# OPENAI_AGENTS_DISABLE_TRACING=1

# 外接观测平台
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=openai-agents-learning

LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

LOGFIRE_TOKEN=

# Multi-provider（用 LiteLLM 时）
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Realtime / Voice
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview
